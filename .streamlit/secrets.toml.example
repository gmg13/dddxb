# Copy this into Streamlit Cloud → App → Settings → Secrets (do NOT commit the real
# file; .streamlit/secrets.toml is gitignored). For local testing you may create
# .streamlit/secrets.toml with the same keys.

# Shared password gating the whole app. Remove to make the app fully public.
app_password = "choose-a-shared-password"

# Powers the "Ask" chatbot. Omit to disable chat (the rest of the app still works).
# Everyone with the password shares this key's usage — set a spend cap in the console.
ANTHROPIC_API_KEY = "sk-ant-..."

# Optional: max chatbot questions per browser session (default 20). Bounds API spend.
# max_chat_messages = 20
